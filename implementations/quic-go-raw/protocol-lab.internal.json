{
  "schemaVersion": "protocol-lab-internal-execution-v1",
  "environments": [
    {
      "os": "linux",
      "arch": "x64",
      "entrypoint": {
        "kind": "process",
        "path": "bin/linux-x64/quic-go-raw",
        "arguments": [],
        "workingDirectory": "."
      }
    }
  ],
  "dependencies": {
    "requiresDotNet": false,
    "requiresDocker": false,
    "requiresPwsh": false,
    "requiresBash": false,
    "requiresGo": false,
    "requiredCapabilities": [
      {
        "name": "quic",
        "value": "true"
      }
    ],
    "modules": [
      {
        "name": "github.com/quic-go/quic-go",
        "version": "v0.60.0",
        "sourceRepository": "https://github.com/quic-go/quic-go"
      }
    ]
  },
  "commands": {
    "buildTemplate": "go build -trimpath -ldflags '-s -w -X main.quicGoVersion=v0.60.0' -o bin/linux-x64/quic-go-raw ./source/cmd/quic-go-raw",
    "serverTemplate": "bin/linux-x64/quic-go-raw",
    "planOnly": "pwsh ./run.ps1 -PlanOnly"
  },
  "knownLimitations": [
    "Server-only raw QUIC transport package; it does not provide HTTP/3.",
    "The initial package advertises only stream throughput and 100-stream multiplexing scenarios.",
    "The package uses generated local self-signed TLS material and ALPN plab-raw-quic."
  ]
}
