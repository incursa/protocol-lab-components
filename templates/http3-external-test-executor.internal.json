{
  "schemaVersion": "protocol-lab-internal-execution-v1",
  "environments": [
    {
      "os": "windows",
      "arch": "x64",
      "entrypoint": {
        "kind": "pwsh",
        "path": "execute.ps1",
        "arguments": [],
        "workingDirectory": "."
      }
    },
    {
      "os": "linux",
      "arch": "x64",
      "entrypoint": {
        "kind": "bash",
        "path": "execute.sh",
        "arguments": [],
        "workingDirectory": "."
      }
    }
  ],
  "dependencies": {
    "requiresDotNet": false,
    "requiresDocker": true,
    "requiresPwsh": true,
    "requiresBash": true,
    "requiresGo": false,
    "requiredCapabilities": [
      {
        "name": "docker",
        "value": "true"
      },
      {
        "name": "http3-runtime",
        "value": "true"
      }
    ],
    "images": [
      {
        "name": "example-http3-tool",
        "image": "example/http3-tool:0.1.0",
        "resolvedImageId": "sha256:replace-with-local-docker-inspect-id",
        "repoDigest": "example/http3-tool@sha256:replace-with-local-docker-inspect-digest"
      }
    ]
  }
}
