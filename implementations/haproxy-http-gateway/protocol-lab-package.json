{
  "schemaVersion": "protocol-lab-package-v2",
  "packageId": "org.protocol-lab.components.implementation.haproxy-http-gateway",
  "packageVersion": "0.1.3",
  "kind": "implementation",
  "displayName": "HAProxy HTTP Gateway Implementations",
  "entryManifests": [
    "implementations/haproxy-http1-gateway.yaml",
    "implementations/haproxy-http2-gateway.yaml",
    "implementations/haproxy-http3-gateway.yaml"
  ],
  "providedImplementations": [
    {"implementationId": "haproxy-http1-gateway", "displayName": "HAProxy HTTP/1.1 Gateway", "protocols": ["h1"], "scenarios": ["http1.core.plaintext", "http1.core.json"]},
    {"implementationId": "haproxy-http2-gateway", "displayName": "HAProxy HTTP/2 Gateway", "protocols": ["h2"], "scenarios": ["http2.core.plaintext", "http2.core.json"]},
    {"implementationId": "haproxy-http3-gateway", "displayName": "HAProxy HTTP/3 Gateway", "protocols": ["h3"], "scenarios": ["http3.core.status", "http3.payload.bytes.1kb", "http3.payload.bytes.64kb"]}
  ],
  "dependencies": {
    "requiredCapabilities": [
      {"name": "docker", "value": "true"},
      {"name": "linux-containers", "value": "true"}
    ]
  }
}
