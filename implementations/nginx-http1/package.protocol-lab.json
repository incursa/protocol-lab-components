{
  "packageId": "org.protocol-lab.components.implementation.nginx-http1",
  "packageKind": "implementation",
  "version": "0.1.2",
  "component": {
    "name": "nginx-http1",
    "family": "nginx",
    "role": "server",
    "protocols": [
      "h1"
    ]
  },
  "entrypoints": {
    "launch": {
      "type": "command",
      "command": "./run.ps1",
      "workingDirectory": "."
    }
  },
  "capabilities": {
    "supported": [
      "http.server",
      "httpPlaintext",
      "httpJson"
    ],
    "supportedProtocols": [
      "h1"
    ],
    "supportedProtocolVersions": [
      "http/1.1"
    ],
    "supportedTestCaseIds": [
      "http1.core.plaintext",
      "http1.core.json"
    ],
    "supportedScenarios": [
      "http1.core.plaintext",
      "http1.core.json"
    ],
    "unsupportedKnownCases": [
      "h2",
      "h3",
      "https",
      "request-body-echo",
      "server-sent-events"
    ]
  },
  "requirements": {
    "os": [
      "linux",
      "windows"
    ],
    "runtimes": [
      "Pinned nginx 1.29.0 Alpine OCI image"
    ],
    "ports": [
      {
        "name": "http",
        "protocol": "tcp",
        "default": 8080
      }
    ],
    "externalTools": [
      "docker"
    ]
  },
  "provenance": {
    "sourcePath": "implementations/nginx-http1",
    "owners": [
      "protocol-lab-components"
    ],
    "licenseNotes": "nginx is BSD-2-Clause licensed; the package redistributes configuration and pins the official runtime image by digest."
  }
}
