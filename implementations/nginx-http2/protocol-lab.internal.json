      {
        "name": "docker",
        "value": "true"
      }
    ],
    "images": [
      {
        "name": "nginx-http2",
        "image": "incursa-protocol-lab-nginx-http2:0.1.1",
        "baseImage": "nginx:1.29.0-alpine",
        "baseImageIndexDigest": "nginx@sha256:d67ea0d64d518b1bb04acde3b00f722ac3e9764b3209a9b0a98924ba35e4b779",
        "baseImageLinuxAmd64Digest": "nginx@sha256:845b5424415de5f77dd5753cbb7c1be8bd8e44cc81f20f9705783a02f8848317",
        "sourceVersion": "release-1.29.0",
