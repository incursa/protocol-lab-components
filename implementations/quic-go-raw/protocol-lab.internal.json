{
  "schemaVersion": "protocol-lab-internal-execution-v1",
  "environments": [
    {
      "os": "linux",
      "arch": "x64",
      "entrypoint": {
        "kind": "process",
        "path": "bin/linux-x64/quic-go-raw",
        "arguments": [],
        "workingDirectory": "."
      }
    },
    {
      "os": "windows",
      "arch": "x64",
      "entrypoint": {
        "kind": "process",
        "path": "bin/windows-x64/quic-go-raw.exe",
        "arguments": [],
        "workingDirectory": "."
      }
    }
  ],
  "dependencies": {
    "requiresDotNet": false,
    "requiresDocker": false,
    "requiresPwsh": false,
    "requiresBash": false,
    "requiresGo": false,
    "requiredCapabilities": [
      {
        "name": "quic",
        "value": "true"
      }
    ],
    "modules": [
      {
        "name": "github.com/quic-go/quic-go",
        "version": "v0.60.0",
        "sourceRepository": "https://github.com/quic-go/quic-go"
      }
    ]
  },
  "commands": {
    "buildTemplate": "pwsh ../../scripts/package/Build-QuicGoRawPackage.ps1",
    "serverTemplate": "pwsh ./run.ps1",
    "planOnly": "pwsh ./run.ps1 -PlanOnly"
  },
  "knownLimitations": [
    "Server-only raw QUIC transport package; it does not provide HTTP/3.",
    "The package advertises stream throughput, sustained upload and download writes, uniform and mixed-size multiplexing, connection churn, stream churn, cold handshake, and duplex scenarios; resumption and 0-RTT remain unsupported until executable proof exists.",
    "The package uses generated local self-signed TLS material and ALPN plab-raw-quic."
  ]
}
