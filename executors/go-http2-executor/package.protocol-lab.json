{
  "packageId": "org.protocol-lab.components.executor.go-http2-executor",
  "packageKind": "test-executor",
  "version": "0.3.0",
  "component": {
    "name": "go-http2-executor",
    "family": "go-http",
    "role": "test-executor",
    "protocols": [
      "h2"
    ]
  },
  "entrypoints": {
    "execute": {
      "type": "command",
      "command": "./execute.ps1",
      "workingDirectory": "."
    }
  },
  "capabilities": {
    "supported": [
      "http.validation",
      "http.exact-protocol-proof",
      "http.payload-sha256",
      "http.load-generation",
      "http.normalized-metrics",
      "http2.h2c-prior-knowledge",
      "http2.topology-proof",
      "http2.profile-concurrency-proof",
      "http2.comparison-16x128x8-balanced-round-robin",
      "httpPlaintext",
      "httpJson"
    ],
    "supportedProtocols": [
      "h2"
    ],
    "supportedProtocolVersions": [
      "http/2-h2c-prior-knowledge"
    ],
    "supportedTestCaseIds": [
      "http2.core.plaintext",
      "http2.core.json"
    ],
    "supportedScenarios": [
      "http2.core.plaintext",
      "http2.core.json"
    ],
    "unsupportedKnownCases": [
      "h1",
      "h3",
      "https",
      "http2-tls-alpn",
      "http2.streaming.response",
      "websocket"
    ]
  },
  "requirements": {
    "os": [
      "linux",
      "windows"
    ],
    "runtimes": [],
    "ports": [],
    "externalTools": []
  },
  "provenance": {
    "sourcePath": "executors/go-http2-executor",
    "owners": [
      "protocol-lab-components"
    ],
    "licenseNotes": "The executor uses the BSD-3-Clause golang.org/x/net/http2 module v0.57.0 and includes the applicable license text."
  }
}
