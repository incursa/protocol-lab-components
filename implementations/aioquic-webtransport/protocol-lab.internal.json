{
  "schemaVersion": "protocol-lab-internal-execution-v1",
  "environments": [
    {"os": "windows", "arch": "x64", "entrypoint": {"kind": "pwsh", "path": "run.ps1", "arguments": [], "workingDirectory": "."}},
    {"os": "linux", "arch": "x64", "entrypoint": {"kind": "bash", "path": "run.sh", "arguments": [], "workingDirectory": "."}}
  ],
  "dependencies": {
    "requiresDotNet": false,
    "requiresDocker": true,
    "requiresPwsh": true,
    "requiresBash": true,
    "requiresGo": false,
    "requiredCapabilities": [{"name": "docker", "value": "true"}, {"name": "http3-runtime", "value": "true"}, {"name": "python", "value": "3.12-slim"}, {"name": "aioquic", "value": "1.3.0"}],
    "images": [{
      "name": "aioquic-webtransport",
      "image": "incursa-protocol-lab-aioquic-webtransport:0.1.1",
      "baseImage": "python:3.12-slim",
      "package": "aioquic==1.3.0",
      "sourceRepository": "https://github.com/aiortc/aioquic",
      "sourceTag": "1.3.0",
      "sourceTagCommit": "cb103537126bbcc58752fd5bc7c8ac88bf552c01"
    }]
  },
  "commands": {
    "buildTemplate": "docker build --pull -f docker/Dockerfile -t incursa-protocol-lab-aioquic-webtransport:0.1.1 .",
    "serverTemplate": "docker run --rm -p <port>:4433/udp incursa-protocol-lab-aioquic-webtransport:0.1.1"
  },
  "knownLimitations": [
    "The package exposes only the exact webtransport.session-bidi-echo lane.",
    "The committed self-signed certificate is for webtransport.plab.test and is accepted only by the pinned test executor trust profile.",
    "WebTransport datagrams, multiple streams, browser APIs, and MASQUE are not claimed."
  ]
}
