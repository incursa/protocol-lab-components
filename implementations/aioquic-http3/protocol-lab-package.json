{
  "schemaVersion": "protocol-lab-package-v2",
  "packageId": "org.protocol-lab.components.implementation.aioquic-http3",
  "packageVersion": "0.3.6",
  "kind": "implementation",
  "displayName": "aioquic HTTP/3 Implementation Wrapper",
  "entryManifests": [
    "implementations/aioquic-http3.yaml"
  ],
  "providedImplementations": [
    {
      "implementationId": "aioquic-http3",
      "displayName": "aioquic HTTP/3",
      "protocols": [
        "h3"
      ],
      "scenarios": [
        "http3.core.plaintext",
        "http3.core.json",
        "http3.core.status",
        "http3.payload.bytes.1kb",
        "http3.payload.bytes.64kb",
        "http3.headers.response-headers-50x32",
        "http3.protocol.qpack-repeated-headers",
        "http3.websocket.rfc9220.extended-connect",
        "http3.websocket.rfc9220.control-frames",
        "http3.websocket.rfc9220.text-echo",
        "http3.websocket.rfc9220.binary-echo",
        "http3.websocket.rfc9220.close",
        "http3.websocket.rfc9220.fragmented-binary-echo"
      ]
    }
  ],
  "dependencies": {
    "requiredCapabilities": [
      {
        "name": "docker",
        "value": "true"
      },
      {
        "name": "http3-runtime",
        "value": "true"
      }
    ]
  }
}
