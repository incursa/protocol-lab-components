  "requirements": {
    "os": [
      "linux",
      "windows"
    ],
    "runtimes": [
      "Go 1.23 or newer for local source run"
    ],
    "ports": [],
    "externalTools": [
      "go"
    ]
  },
  "provenance": {
    "sourcePath": "executors/go-http1-executor",
    "owners": [
      "protocol-lab-components"
    ],
    "licenseNotes": "Confirm Go module dependency licenses before publishing binary artifacts."
  }
