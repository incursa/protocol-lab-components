{
  "packageId": "org.protocol-lab.components.executor.go-http1-executor",
  "packageKind": "test-executor",
  "version": "0.1.0",
  "component": {
    "name": "go-http1-executor",
    "family": "go-http",
    "role": "test-executor",
    "protocols": [
      "h1"
    ]
  },
  "entrypoints": {
    "execute": {
      "type": "command",
      "command": "./execute.ps1",
      "workingDirectory": "."
    }
  },
  "capabilities": {
