{
  "schemaVersion": "protocol-lab-internal-execution-v1",
  "environments": [
    {
      "os": "linux",
      "arch": "x64",
      "entrypoint": {
        "kind": "process",
        "path": "bin/linux-x64/s2n-quic-raw",
        "arguments": [],
        "workingDirectory": "."
      }
    }
  ],
  "dependencies": {
    "requiresDotNet": false,
    "requiresDocker": false,
    "requiresPwsh": false,
    "requiresBash": false,
    "requiresGo": false,
    "requiredCapabilities": [
      {
        "name": "quic",
        "value": "true"
      }
    ],
    "modules": [
      {
        "name": "s2n-quic",
        "version": "1.83.0",
        "sourceRepository": "https://github.com/aws/s2n-quic"
      }
    ]
  },
  "commands": {
    "buildTemplate": "pwsh ../../scripts/package/Build-S2nQuicRawPackage.ps1",
    "serverTemplate": "bash ./run.sh",
    "planOnly": "PLAB_PLAN_ONLY=1 bash ./run.sh"
  },
  "knownLimitations": [
    "Server-only raw QUIC transport package; it does not provide HTTP/3.",
    "Only the five declared ProtocolLab raw transport scenarios are supported until additional exact wire behavior is implemented and proven.",
    "The package uses generated local self-signed TLS material, the rustls provider, and ALPN plab-raw-quic."
  ]
}
