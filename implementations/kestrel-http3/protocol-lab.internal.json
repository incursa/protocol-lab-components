{
  "schemaVersion": "protocol-lab-internal-execution-v1",
  "environments": [
    {
      "os": "windows",
      "arch": "x64",
      "entrypoint": {
        "kind": "process",
        "path": "dotnet",
        "arguments": ["run", "--project", "src/KestrelHttp3.csproj", "--no-launch-profile"],
        "workingDirectory": "."
      }
    },
    {
      "os": "linux",
      "arch": "x64",
      "entrypoint": {
        "kind": "process",
        "path": "dotnet",
        "arguments": ["run", "--project", "src/KestrelHttp3.csproj", "--no-launch-profile"],
        "workingDirectory": "."
      }
    }
  ],
  "dependencies": {
    "requiresDotNet": true,
    "requiresDocker": false,
    "requiresPwsh": true,
    "requiresBash": true,
    "requiresGo": false,
    "requiredCapabilities": [
      {
        "name": "dotnet-runtime",
        "value": "10"
      },
      {
        "name": "http3-runtime",
        "value": "true"
      }
    ]
  }
}
