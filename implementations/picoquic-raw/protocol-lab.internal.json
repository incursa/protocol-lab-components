{
  "schemaVersion": "protocol-lab-internal-execution-v1",
  "environments": [
    {
      "os": "linux",
      "arch": "x64",
      "entrypoint": {
        "kind": "process",
        "path": "bin/linux-x64/picoquic-raw",
        "arguments": [],
        "workingDirectory": "."
      }
    }
  ],
  "dependencies": {
    "requiresDotNet": false,
    "requiresDocker": false,
    "requiresPwsh": false,
    "requiresBash": true,
    "requiresGo": false,
    "requiredCapabilities": [
      {
        "name": "quic",
        "value": "true"
      }
    ],
    "modules": [
      {
        "name": "picoquic",
        "version": "13671ce7bdf58c278a29da2d49a32f76c21d6c6d",
        "sourceRepository": "https://github.com/private-octopus/picoquic"
      },
      {
        "name": "picotls",
        "version": "bfa67875982afc4c24f21e146cef4747fa189c2f",
        "sourceRepository": "https://github.com/h2o/picotls"
      }
    ]
  },
  "commands": {
    "buildTemplate": "pwsh ../../scripts/package/Build-PicoquicRawPackage.ps1",
    "serverTemplate": "bash ./run.sh",
    "planOnly": "PLAB_PLAN_ONLY=1 bash ./run.sh"
  },
  "knownLimitations": [
    "Server-only raw QUIC transport package; it does not provide HTTP/3.",
    "Only the five declared ProtocolLab raw transport scenarios are supported until additional exact wire behavior is implemented and proven.",
    "The package uses picoquic's pinned upstream local test certificate, its picotls/OpenSSL provider, and ALPN plab-raw-quic."
  ]
}
