{
  "schemaVersion": "protocol-lab-internal-execution-v1",
  "environments": [
    {
      "os": "windows",
      "arch": "x64",
      "entrypoint": {
        "kind": "pwsh",
        "path": "run.ps1",
        "arguments": [],
        "workingDirectory": "."
      }
    },
    {
      "os": "linux",
      "arch": "x64",
      "entrypoint": {
        "kind": "bash",
        "path": "run.sh",
        "arguments": [],
        "workingDirectory": "."
      }
    }
  ],
  "dependencies": {
    "requiresDotNet": false,
    "requiresDocker": true,
    "requiresPwsh": true,
    "requiresBash": true,
    "requiresGo": false,
    "requiredCapabilities": [
      {
        "name": "docker",
        "value": "true"
      },
      {
        "name": "python",
        "value": "3.12-slim"
      },
      {
        "name": "aioquic",
        "value": "1.3.0"
      }
    ],
    "images": [
      {
        "name": "aioquic-http3",
        "image": "incursa-protocol-lab-aioquic-http3:0.3.4",
        "baseImage": "python:3.12-slim",
        "package": "aioquic==1.3.0"
      }
    ]
  },
  "commands": {
    "buildTemplate": "docker build --build-arg AIOQUIC_VERSION=1.3.0 -f docker/aioquic.Dockerfile -t incursa-protocol-lab-aioquic-http3:0.3.4 .",
    "clientTemplate": "aioquic-http3-client <url> <download-path> --expect-status <status>",
    "serverTemplate": "aioquic-http3-server /www /certs/cert.pem /certs/priv.key 4433"
  },
  "knownLimitations": [
    "Large-body client rows may be skipped when aioquic 1.3.0 response completion stalls are observed.",
    "Server wrapper is static-file oriented and intended for external peer characterization.",
    "RFC9220 WebSocket-over-H3 support is limited to the six exact committed identities at /websocket-proof.",
    "Fragmented binary support accepts only the committed 1024, 2048, and 2928 byte frame plan without interleaved control frames."
  ],
  "externalInteropEvidence": {
    "evidenceClass": "external-peer-characterization",
    "passingRows": [
      {
        "target": "aioquic-client__incursa-server",
        "scenarios": [
          "get-small",
          "not-found"
        ],
        "artifactRun": "C:/src/incursa/quic-dotnet/.artifacts/http3-external/20260619T055801Z"
      },
      {
        "target": "incursa-client__aioquic-server",
        "scenarios": [
          "get-small",
          "not-found"
        ],
        "artifactRun": "C:/src/incursa/quic-dotnet/.artifacts/http3-external/20260619T055801Z"
      }
    ],
    "skippedRows": [
      {
        "target": "aioquic-client__incursa-server",
        "scenarios": [
          "get-large"
        ],
        "artifactRun": "C:/src/incursa/quic-dotnet/.artifacts/http3-external/20260619T055646Z",
        "reason": "aioquic 1.3.0 large-body peer incompatibility; rows remain documented skips until the peer library is upgraded or replaced."
      },
      {
        "target": "incursa-client__aioquic-server",
        "scenarios": [
          "get-large"
        ],
        "artifactRun": "C:/src/incursa/quic-dotnet/.artifacts/http3-external/20260619T055646Z",
        "reason": "aioquic 1.3.0 large-body peer incompatibility; rows remain documented skips until the peer library is upgraded or replaced."
      }
    ]
  }
}
