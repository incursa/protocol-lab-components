{
  "schemaVersion": "protocol-lab-internal-execution-v1",
  "environments": [
    {
      "os": "windows",
      "arch": "x64",
      "entrypoint": {
        "kind": "pwsh",
        "path": "execute.ps1",
        "arguments": [],
        "workingDirectory": "."
      }
    },
    {
      "os": "linux",
      "arch": "x64",
      "entrypoint": {
        "kind": "bash",
        "path": "execute.sh",
        "arguments": [],
        "workingDirectory": "."
      }
    }
  ],
  "dependencies": {
    "requiresDotNet": false,
    "requiresDocker": true,
    "requiresPwsh": true,
    "requiresBash": true,
    "requiresGo": false,
    "requiredCapabilities": [
      {
        "name": "docker",
        "value": "true"
      },
      {
        "name": "python",
        "value": "3.12-slim"
      },
      {
        "name": "aioquic",
        "value": "1.3.0"
      }
    ],
    "images": [
      {
        "name": "aioquic-rfc9220-websocket",
        "image": "incursa-protocol-lab-aioquic-rfc9220-websocket:0.3.0",
        "baseImage": "python:3.12-slim",
        "package": "aioquic==1.3.0"
      }
    ]
  },
  "commands": {
    "buildTemplate": "docker build --build-arg AIOQUIC_VERSION=1.3.0 -f docker/aioquic-rfc9220-websocket.Dockerfile -t incursa-protocol-lab-aioquic-rfc9220-websocket:0.3.0 .",
    "clientTemplate": "aioquic-http3-websocket-client <url> <result-path> --scenario-id <exact-id> --load-profile-id <exact-profile> --package-and-image-digests <immutable-values>"
  },
  "knownLimitations": [
    "Executor-only package; it does not start or own the target HTTP/3 WebSocket server lifecycle.",
    "The executor requires one exact committed RFC9220 scenario identity and never substitutes another operation.",
    "The fragmented diagnostic is exactly 6000 bytes of 0xA5 in masked frame payloads 1024, 2048, and 2928 with no interleaved control frame.",
    "This package is RFC9220 WebSocket-over-H3 diagnostic evidence, not broad WebSocket interoperability coverage.",
    "Package and image digests are mandatory; execution fails closed when immutable materialization proof is absent."
  ]
}
