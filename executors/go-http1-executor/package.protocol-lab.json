      "http.validation",
      "httpPlaintext",
      "httpJson"
    ],
    "supportedProtocols": [
      "h1"
    ],
    "supportedProtocolVersions": [
      "http/1.1"
    ],
    "supportedTestCaseIds": [
      "http.core.plaintext",
      "http.core.json"
